#!/usr/bin/env bash

# After adding or upgrading a third-party dependency, run this script to
# regenerate the language lockfiles. Also run once after `aspect init` to
# materialize the placeholder lockfiles the template ships with.
set -o errexit -o nounset -o pipefail

cd "$(dirname "$0")/.."

# Python: recompile the pip locks and refresh the gazelle manifest.
bazel run //requirements:runtime.update
bazel run //requirements:requirements.all.update
bazel run //:gazelle_python_manifest.update


# JavaScript: refresh pnpm-lock.yaml from package.json (lockfile only).
bazel run -- @pnpm --dir="$PWD" install --lockfile-only


# Java: re-pin Maven artifacts into maven_install.json.
bazel run @unpinned_maven//:pin


# Ruby: Gemfile.lock must be regenerated with a Ruby matching .ruby-version.
# rules_ruby has no in-tree relock target, so use a container (or a local Ruby):
#   docker run --rm -v "$PWD":/w -w /w ruby:$(cat .ruby-version) \
#     bundle lock --add-platform ruby x86_64-linux aarch64-linux \
#       aarch64-linux-musl x86_64-linux-musl arm64-darwin x86_64-darwin
echo "ruby: regenerate Gemfile.lock with 'bundle lock' (see comment in tools/repin)"

# Accept any resulting MODULE.bazel.lock changes.
bazel mod deps --lockfile_mode=update